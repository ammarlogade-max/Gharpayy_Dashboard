{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/capture/layout,_N_T_/capture/page,_N_T_/capture"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/capture/__PAGE__",
    "/capture",
    "/_index",
    "/_head"
  ]
}